# ══════════════════════════════════════════════════
# ColoniaPress — Variables de Entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a Git
# ══════════════════════════════════════════════════

# ── ANTHROPIC (REQUERIDO) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── BASE DE DATOS ─────────────────────────────────
# SQLite (desarrollo)
DB_PATH=./data/coloniapress.db
# PostgreSQL (producción) — descomenta al migrar:
# DATABASE_URL=postgresql://user:pass@host:5432/coloniapress

# ── SERVIDOR ──────────────────────────────────────
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# ── SCRAPING ──────────────────────────────────────
SCRAPE_INTERVAL_MIN=15
MAX_ARTICLES_PER_CYCLE=20

# ── EMAIL (RESEND.COM — gratis 3k/mes) ────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noticias@coloniapress.mx

# ── TWITTER / X (API v2) ──────────────────────────
# Crear en: developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── FACEBOOK / META ───────────────────────────────
# Crear en: developers.facebook.com
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# ── INSTAGRAM ─────────────────────────────────────
# Usa la API de Meta Business (misma app que Facebook)
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ── GOOGLE ADSENSE ────────────────────────────────
ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx
ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# ── DOMINIO ───────────────────────────────────────
SITE_URL=https://coloniapress.mx
ADMIN_SECRET=cambia-esto-por-un-secreto-seguro
